// ============================================================
// nextflow.config — main entry point
// Includes sub-configs and defines execution profiles.
//
// Usage:
//   nextflow run main.nf -profile local
//   nextflow run main.nf -profile local --mini_config=1
//   nextflow run main.nf -profile slurm
//   nextflow run main.nf -profile slurm --mini_config=1
// ============================================================

// Global defaults
params.outdir      = './output'
params.mini_config = 0

// Always enable apptainer regardless of profile
apptainer {
    enabled    = true
    autoMounts = true
}

process {
    container = "${params.projectRoot}/containers/gegelati-armlearn.sif"
}

// ============================================================
// Profiles
// ============================================================
profiles {

    // ----------------------------------------------------------
    // local: run everything on the current machine (default)
    // ----------------------------------------------------------
    local {
        process.executor = 'local'
    }

    // ----------------------------------------------------------
    // slurm: submit jobs to a SLURM cluster via Apptainer
    // ----------------------------------------------------------
    slurm {
        process.executor = 'slurm'
        process.beforeScript = 'export PATH=/usr/bin:$PATH'

        apptainer {
            enabled    = true
            autoMounts = true
            runOptions = "--bind ${projectDir} --bind /etc/munge --bind /run/munge --bind /etc/slurm"
        }

    }

    // ----------------------------------------------------------
    // mini: lightweight resources, activated automatically by
    // the launcher when --mini_config=N (N > 0) is passed.
    // Stacks with local or slurm: -profile local,mini
    // ----------------------------------------------------------
    mini {
        params.nb_generations  = 1
        params.training_time   = 240  // seconds
        params.training_cores  = 1
        params.memory          = '1 GB'
    }
}