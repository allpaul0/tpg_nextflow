params.trained_TPGs_path = 'output/training_results/*'

process {

    // 'slurm'
    executor = 'local'
    
    withName:generate_code {
        container = "${params.projectRoot}/containers/nextflow-insa.sif"
    }

    withName:export_LE_states {
        container = "${params.projectRoot}/containers/nextflow-insa.sif"
    }
     
}